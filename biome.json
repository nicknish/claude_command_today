{
	"$schema": "https://biomejs.dev/schemas/2.3.13/schema.json",
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on"
				}
			}
		}
	},
	"files": {
		"includes": [
			"src/**",
			"vitest.config.ts",
			"!**/node_modules",
			"!**/dist",
			"!**/artifacts",
			"!**/logs"
		]
	}
}
